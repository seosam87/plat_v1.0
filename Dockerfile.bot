FROM python:3.12-slim

WORKDIR /opt/app

# System deps for asyncpg + git for agent branch operations + curl for nodesource
RUN apt-get update && apt-get install -y --no-install-recommends \
    gcc libpq-dev curl git \
    && rm -rf /var/lib/apt/lists/*

# Node.js 20 + Claude Code CLI (per D-02)
RUN curl -fsSL https://deb.nodesource.com/setup_20.x | bash - \
    && apt-get install -y --no-install-recommends nodejs \
    && npm install -g @anthropic-ai/claude-code \
    && rm -rf /var/lib/apt/lists/*

# Git identity for merge commits (per Research Open Question 2)
RUN git config --global user.name "Claude Agent" \
    && git config --global user.email "agent@seo-platform"

# Install main project requirements (for shared app.models, app.config, etc.)
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Install bot-specific requirements
COPY bot/requirements.txt bot/requirements.txt
RUN pip install --no-cache-dir -r bot/requirements.txt

# Copy application code (app/ for models+config, bot/ for bot logic)
COPY app/ app/
COPY bot/ bot/
COPY alembic/ alembic/
COPY alembic.ini .

CMD ["python", "-m", "bot.main"]
