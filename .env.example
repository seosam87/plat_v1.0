# Database
POSTGRES_USER=seo_user
POSTGRES_PASSWORD=changeme
POSTGRES_DB=seo_platform
DATABASE_URL=postgresql+asyncpg://seo_user:changeme@postgres:5432/seo_platform
SYNC_DATABASE_URL=postgresql+psycopg2://seo_user:changeme@postgres:5432/seo_platform

# Redis
REDIS_URL=redis://redis:6379/0

# JWT — generate with: openssl rand -hex 32
SECRET_KEY=replace-with-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Celery
CELERY_WORKER_CONCURRENCY=8

# Fernet — generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=replace-with-generated-key

# Crawler
CRAWLER_DELAY_MS=500
CRAWLER_MAX_PAGES=500

# Google Search Console OAuth 2.0 (leave empty to disable)
GSC_CLIENT_ID=
GSC_CLIENT_SECRET=
GSC_REDIRECT_URI=http://localhost:8000/gsc/callback

# DataForSEO (leave empty to disable)
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=

# Yandex Webmaster (leave empty to disable)
YANDEX_WEBMASTER_TOKEN=

# Playwright SERP parser
SERP_MAX_DAILY_REQUESTS=50
SERP_DELAY_MS=3000

# Telegram alerts (leave empty to disable)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
POSITION_DROP_THRESHOLD=5

# Flower (Celery monitoring)
FLOWER_BASIC_AUTH=admin:changeme

# App
DB_ECHO=false
LOG_LEVEL=INFO
