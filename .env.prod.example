# =============================================================================
# Production environment — copy to .env.prod and fill in real values
# =============================================================================

# Database
POSTGRES_USER=seo_user
POSTGRES_PASSWORD=          # openssl rand -base64 32
POSTGRES_DB=seo_platform
DATABASE_URL=postgresql+asyncpg://seo_user:PASSWORD_HERE@postgres:5432/seo_platform
SYNC_DATABASE_URL=postgresql+psycopg2://seo_user:PASSWORD_HERE@postgres:5432/seo_platform

# Redis (set a password in production)
REDIS_PASSWORD=             # openssl rand -base64 32
REDIS_URL=redis://:REDIS_PASSWORD_HERE@redis:6379/0

# JWT — MUST generate: openssl rand -hex 32
SECRET_KEY=
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Fernet — MUST generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=

# Uvicorn
UVICORN_WORKERS=2

# Celery
CELERY_WORKER_CONCURRENCY=4

# Crawler
CRAWLER_DELAY_MS=500
CRAWLER_MAX_PAGES=500

# Google Search Console OAuth 2.0 (leave empty to disable)
GSC_CLIENT_ID=
GSC_CLIENT_SECRET=
GSC_REDIRECT_URI=https://YOUR_DOMAIN/gsc/callback

# DataForSEO (leave empty to disable)
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=

# Yandex Webmaster (leave empty to disable)
YANDEX_WEBMASTER_TOKEN=

# Playwright SERP parser
SERP_MAX_DAILY_REQUESTS=50
SERP_DELAY_MS=3000

# Telegram alerts (leave empty to disable)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
POSITION_DROP_THRESHOLD=5

# Flower (Celery monitoring) — change password!
FLOWER_BASIC_AUTH=admin:CHANGE_THIS_PASSWORD

# App
DB_ECHO=false
LOG_LEVEL=INFO
